VITE_API_BASE=https://radioinonestop-backend-production.up.railway.app
# Vite dev proxy defaults to hosted edge for media routes.
VITE_WEBRTC_PROXY_TARGET=https://radioinonestop.com
VITE_HLS_PROXY_TARGET=https://radioinonestop.com

# Enable these only when proxying directly to local MediaMTX ports.
# VITE_WEBRTC_PROXY_TARGET=http://localhost:8889
# VITE_HLS_PROXY_TARGET=http://localhost:8888
# VITE_WEBRTC_PROXY_REWRITE=true
# VITE_HLS_PROXY_REWRITE=true

VITE_PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID_HERE
